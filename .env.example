# --- Local orchestrator ---
# Daytona API key (https://app.daytona.io -> Keys)
DAYTONA_API_KEY=
# Optional: Daytona target region / API URL (leave blank for default)
DAYTONA_TARGET=
DAYTONA_API_URL=

# --- Passed into the sandbox for OpenCode ---
# Dedicated provider key for this POC. OpenCode auto-reads OPENAI_API_KEY.
# If you switch SANDBOX_MODEL to anthropic/*, set SANDBOX_ANTHROPIC_API_KEY instead.
SANDBOX_OPENAI_API_KEY=
SANDBOX_ANTHROPIC_API_KEY=

# Model OpenCode should use, in "provider/model" form.
SANDBOX_MODEL=openai/gpt-4o

# Delete the sandbox automatically when the run finishes.
AUTO_DELETE_SANDBOX=true
