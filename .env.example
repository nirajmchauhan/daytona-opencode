# --- Local orchestrator ---
# Daytona API key (https://app.daytona.io -> Keys)
DAYTONA_API_KEY=
# Optional: Daytona target region / API URL (leave blank for default)
DAYTONA_TARGET=
DAYTONA_API_URL=

# --- Passed into the sandbox for OpenCode ---
# Provider key for this POC, forwarded into the sandbox as <PROVIDER>_API_KEY.
# The env var name must match the provider in SANDBOX_MODEL:
#   openrouter -> SANDBOX_OPENROUTER_API_KEY  (recommended)
#   openai     -> SANDBOX_OPENAI_API_KEY
#   anthropic  -> SANDBOX_ANTHROPIC_API_KEY
SANDBOX_OPENROUTER_API_KEY=

# Model OpenCode should use. For OpenRouter this is "openrouter/<provider>/<model>".
SANDBOX_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Delete the sandbox automatically when the run finishes.
AUTO_DELETE_SANDBOX=true
